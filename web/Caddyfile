# Reverse proxy for the Hearts web UI.
#
# Caddy listens on :80 and :443, auto-provisions a Let's Encrypt cert for the
# domain, and forwards everything to the uvicorn process (which serves both the
# /api endpoints and the built SPA from web/frontend/dist).
#
# Prereqs:
#   1. DNS: hearts.radiswanson.org A record -> this host's public IP.
#   2. Router: forward external 80 and 443 -> this host.
#   3. Run the app:
#        cd web/frontend && npm run build
#        cd ../backend && RESULTS_DIR=../../results ./.venv/bin/uvicorn main:app --port 8000
#   4. Run Caddy:  caddy run --config web/Caddyfile
#
# For plain HTTP only (no cert), change the site address to
# `http://hearts.radiswanson.org` and forward port 80 only.

hearts.radiswanson.org {
	reverse_proxy localhost:8000
}
