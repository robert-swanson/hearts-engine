# competition_runner.py reads these as defaults (interactive: prompts with these as defaults;
# non-interactive: uses them directly). It then writes this file with TEAMS and port added
# before starting the tournament_server binary. Commit changes to set new competition defaults.

# Competition orchestration
REGISTRATION_WINDOW=60
INTERVAL=300

# Tournament rules
QUALIFYING_GAMES=20
FINALS_GAMES=7
MAX_PLAYERS_PER_TEAM=4
QUALIFYING_POINTS=10,5,3,1
ALLOW_MULTI_TEAM_FINALS=0
RESULTS_DIR=./results
LOG_DIR=./log
AUTO_MOVE_AFTER_TIMEOUTS=2
FALLBACK_PLAYER_TAG=random_player

# Populated at runtime by competition_runner.py after team registration
TEAMS=
